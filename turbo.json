{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": [
        "NODE_ENV",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "DATABASE_URL",
        "REDIS_URL",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL"
      ]
    },
    "type-check": {
      "dependsOn": ["^type-check"]
    },
    "test:unit": {
      "dependsOn": ["^test:unit"]
    },
    "test:integration": {
      "dependsOn": ["^test:integration"]
    },
    "test:e2e": {
      "dependsOn": ["^test:e2e"]
    },
    "security:scan": {
      "dependsOn": ["^security:scan"]
    },
    "lighthouse": {
      "dependsOn": ["^lighthouse"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "NODE_ENV",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "DATABASE_URL",
        "REDIS_URL",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL"
      ]
    }
  }
}
