{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "type-check": {
      "dependsOn": ["^type-check"]
    },
    "test:unit": {
      "dependsOn": ["^test:unit"]
    },
    "test:integration": {
      "dependsOn": ["^test:integration"]
    },
    "test:e2e": {
      "dependsOn": ["^test:e2e"]
    },
    "security:scan": {
      "dependsOn": ["^security:scan"]
    },
    "lighthouse": {
      "dependsOn": ["^lighthouse"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
