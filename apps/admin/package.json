    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/node": "^22.15.3",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.34.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.0",
    "typescript": "5.9.2",
    "vitest": "^3.2.4",
    "@playwright/test": "^1.40.0"
