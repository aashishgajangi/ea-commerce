    "security:scan": "npm audit --audit-level high",
    "lighthouse": "lhci autorun"
  },
  "dependencies": {
    "@repo/ui": "*",
    "next": "^15.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/node": "^22.15.3",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.1",
    "eslint": "^9.34.0",
    "typescript": "5.9.2",
    "vitest": "^1.0.0",
    "@playwright/test": "^1.40.0",
    "@lhci/cli": "^0.12.0"
  }
}
